{
    "name": "lumensistemas/asaas-laravel",
    "description": "Laravel client for the Asaas payment API",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "asaas", "payment", "api"],
    "authors": [
        {
            "name": "Lucas Vasconcelos",
            "email": "lucasvscn@pm.me"
        }
    ],
    "require": {
        "php": ">=8.5",
        "illuminate/http": "^12.53",
        "illuminate/support": "^12.53"
    },
    "require-dev": {
        "beyondcode/expose": "^3.2",
        "friendsofphp/php-cs-fixer": "^3.94",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "LumenSistemas\\Asaas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LumenSistemas\\Asaas\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LumenSistemas\\Asaas\\AsaasServiceProvider"
            ],
            "aliases": {
                "Asaas": "LumenSistemas\\Asaas\\Facades\\Asaas"
            }
        }
    },
    "scripts": {
        "lint": [
            "rector process --memory-limit=512M --ansi",
            "php-cs-fixer fix --allow-risky=yes --ansi"
        ],
        "analyse": "phpstan analyse --memory-limit=512M --ansi",
        "test": "pest",
        "test:coverage": [
            "pest --type-coverage --min=100",
            "pest --coverage --min=90"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
