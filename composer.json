{
    "name": "lumensistemas/asaas-laravel",
    "description": "A Laravel package for integrating with the Asaas payment gateway API.",
    "keywords": [
        "lumensistemas",
        "asaas-laravel",
        "asaas",
        "payment-gateway",
        "laravel"
    ],
    "homepage": "https://github.com/lumensistemas/asaas-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Lucas Vasconcelos",
            "email": "lucasvscn@pm.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "beyondcode/expose": "^3.2",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.9",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "LumenSistemas\\Asaas\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LumenSistemas\\Asaas\\Tests\\": "tests"
        }
    },
    "scripts": {
        "lint": [
            "rector process --memory-limit=512M --ansi",
            "pint --ansi"
        ],
        "analyse": "phpstan analyse --memory-limit=512M --ansi",
        "test:lint": [
            "rector process --clear-cache --dry-run --memory-limit=512M --ansi",
            "pint --test --ansi"
        ],
        "test": "pest",
        "test:type-coverage": "pest --type-coverage --min=100 --memory-limit=512M",
        "test:coverage": "pest --coverage --min=90",
        "webhook:serve": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:${ASAAS_WEBHOOK_SERVER_PORT:-9876} scripts/webhook-server.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
